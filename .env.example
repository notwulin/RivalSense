# Flask
PORT=5001
FLASK_DEBUG=true
SECRET_KEY=rivalsense-dev-key
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Frontend / portfolio preview
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_API_URL=http://localhost:5001

# SQLite
# Default: backend/data/rivalsense.db
# SQLITE_PATH=/absolute/path/to/rivalsense.db

# AI summary engine: gemini | deepseek
AI_ENGINE=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Deep page extraction
FIRECRAWL_API_KEY=
JINA_API_KEY=

# Structured search discovery
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
SEARCH_DISCOVERY_ENABLED=true
CHINESE_DISCOVERY_ENABLED=true
SEARCH_MAX_QUERIES=18
SEARCH_RESULTS_PER_QUERY=8
